FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY docker/rag-api-requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY src /app/src
ENV PYTHONPATH=/app/src
EXPOSE 8003
CMD ["uvicorn", "news_ingest.ml.rag_api:app", "--host", "0.0.0.0", "--port", "8003"]
