NEWSAPI_API_KEY=replace-me
CURRENTS_API_KEY=replace-me
GNEWS_API_KEY=replace-me
NYTIMES_API_KEY=replace-me
NEWSDATA_API_KEY=replace-me
THENEWSAPI_TOKEN=replace-me

NEWSAPI_QUERY=technology OR business OR politics OR science OR health
# Optional: semicolon-separated query list. If set, ingestion will move through these queries under the same call budget.
NEWSAPI_QUERIES=technology;business;politics;science;health;artificial intelligence;cybersecurity;climate;finance;startups;sports;entertainment;world news;energy;medicine
NEWSAPI_MAX_CALLS=1000
NEWSAPI_PAGE_SIZE=100
# Currents free tier max page size is 20.
CURRENTS_PAGE_SIZE=20
# Free NewsAPI developer accounts can only access the first 100 results for a query.
NEWSAPI_MAX_PAGES_PER_WINDOW=1
NEWSAPI_LANGUAGE=en
NEWSAPI_SORT_BY=publishedAt
NEWSAPI_TIMEZONE=Europe/London

# GNews free plan commonly supports smaller per-request result counts.
GNEWS_PAGE_SIZE=10
# NYTimes Article Search returns 10 results per page.
NYTIMES_PAGE_SIZE=10
# NewsData.io page size. Keep this conservative for free plans.
NEWSDATA_PAGE_SIZE=10
# TheNewsAPI page size. Keep this conservative unless your plan allows more.
THENEWSAPI_PAGE_SIZE=10

POSTGRES_DB=news_rag
POSTGRES_USER=news_rag
POSTGRES_PASSWORD=news_rag_password
DATABASE_URL=postgresql://news_rag:news_rag_password@localhost:5432/news_rag

# Hugging Face token is required after accepting the EmbeddingGemma license.
HF_TOKEN=replace-me
MODEL_DEVICE=cuda
EMBEDDING_DTYPE=bfloat16
EMBEDDING_MODEL_NAME=google/embeddinggemma-300m
NER_MODEL_NAME=urchade/gliner_multi-v2.1
EMBEDDING_SERVICE_URL=http://localhost:8001
NER_SERVICE_URL=http://localhost:8002

# For GPU mode, set these and run with docker-compose.gpu.yml:
# MODEL_DEVICE=cuda
# EMBEDDING_DTYPE=bfloat16

RAG_API_PORT=8003
# Empty token disables auth for local development. Set a strong token to require Authorization: Bearer <token>.
RAG_API_TOKEN=
RAG_RATE_LIMIT_PER_MINUTE=60
RAG_RATE_LIMIT_BURST=10
RAG_CACHE_TTL_SECONDS=3600
RAG_SEMANTIC_CACHE_THRESHOLD=0.95
RAG_VECTOR_WEIGHT=0.6
RAG_FULL_TEXT_WEIGHT=0.2
RAG_ENTITY_WEIGHT=0.2

# Claude on Vertex AI for /chat and /chat/stream.
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=global
CLAUDE_MODEL=claude-haiku-4-5@20251001
CLAUDE_MAX_TOKENS=1200
CLAUDE_TEMPERATURE=0.2
CLAUDE_THINKING_LOW_TOKENS=512
CLAUDE_THINKING_MEDIUM_TOKENS=1024
CLAUDE_THINKING_MAX_TOKENS=2048
# Use one of these auth options for Docker/local runs:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_VERTEX_AI_KEY={"type":"service_account",...}

# Chat provider. Leave blank to use Bedrock when AWS_BEDROCK_KEY exists, otherwise Vertex.
# Set CHAT_PROVIDER=vertex to force Google Vertex AI.
CHAT_PROVIDER=

# AWS Bedrock for /chat and /chat/stream.
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
# Preferred: standard AWS credentials or a JSON object in AWS_BEDROCK_KEY.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_BEDROCK_KEY={"aws_access_key_id":"...","aws_secret_access_key":"...","region":"us-east-1"}
# AWS_BEDROCK_KEY may also be access_key_id:secret_access_key[:session_token].

# Optional live web search citations for /chat and /chat/stream.
WEB_SEARCH_PROVIDER=bing_news
WEB_SEARCH_TTL_SECONDS=21600
WEB_SEARCH_TIMEOUT_SECONDS=15

# Standalone FastMCP wrapper for the RAG API.
MCP_RAG_API_URL=http://localhost:8003
# Leave empty to reuse RAG_API_TOKEN if set.
MCP_RAG_API_TOKEN=
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8004
MCP_PATH=/mcp
